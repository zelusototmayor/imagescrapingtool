# Database
DATABASE_URL=postgresql://localhost/imagesweep_development

IMAGESWEEP_DATABASE_PASSWORD=your_database_password_here

POSTGRES_PASSWORD=your_postgres_password_here

# Kamal Registry (Docker)
KAMAL_REGISTRY_PASSWORD=your_docker_registry_token_here

# Redis
REDIS_URL=redis://localhost:6379/0

# ImageSweep Configuration
MAX_IMAGES=200
JOB_TIMEOUT_MINUTES=2
USER_AGENT=ImageSweepBot/0.1 (contact: support@imagesweep.app)

# Stripe (for later)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...

# Rate Limiting
RATE_LIMIT_JOBS_PER_HOUR=10

# Playwright Configuration (optional, auto-detected if not set)
# PLAYWRIGHT_CLI_EXECUTABLE_PATH=/path/to/playwright