<div class="max-w-4xl mx-auto p-6">
  <div class="bg-white shadow rounded-lg">
    <div class="px-6 py-4 border-b border-gray-200">
      <h1 class="text-2xl font-bold text-gray-900">Dashboard</h1>
      <p class="text-gray-600">Welcome back, <%= @user.email %></p>
    </div>

    <div class="p-6">
      <!-- Subscription Status -->
      <div class="mb-8">
        <h2 class="text-lg font-semibold mb-4">Subscription Status</h2>
        <div class="bg-gray-50 p-4 rounded-lg">
          <% if @is_premium %>
            <div class="flex items-center">
              <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">
                Premium
              </span>
              <span class="ml-3 text-gray-600">Unlimited downloads</span>
            </div>
          <% else %>
            <div class="space-y-3">
              <div class="flex items-center justify-between">
                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-gray-100 text-gray-800">
                  Free Plan
                </span>
                <span class="text-sm text-gray-600">
                  Downloads used: <%= @downloads_used %> / <%= User::FREE_DOWNLOAD_LIMIT %>
                </span>
              </div>
              <% if @remaining_downloads == 0 %>
                <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4">
                  <p class="text-yellow-800 text-sm">
                    You've reached your download limit. Upgrade to premium for unlimited downloads.
                  </p>
                  <button onclick="upgradeToPremium()" class="mt-2 bg-yellow-600 text-white px-4 py-2 rounded-md text-sm hover:bg-yellow-700">
                    Upgrade Now - €5/month
                  </button>
                </div>
              <% else %>
                <div class="flex items-center justify-between">
                  <span class="text-sm text-gray-600">
                    Remaining downloads: <%= @remaining_downloads %>
                  </span>
                  <button onclick="upgradeToPremium()" class="bg-blue-600 text-white px-4 py-2 rounded-md text-sm hover:bg-blue-700">
                    Upgrade to Premium - €5/month
                  </button>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Recent Jobs -->
      <div class="mb-8">
        <h2 class="text-lg font-semibold mb-4">Recent Jobs</h2>
        <% if @recent_jobs.any? %>
          <div class="space-y-3">
            <% @recent_jobs.each do |job| %>
              <div class="border border-gray-200 rounded-lg p-4">
                <div class="flex items-center justify-between">
                  <div>
                    <p class="font-medium text-gray-900"><%= job.url %></p>
                    <p class="text-sm text-gray-600">
                      Status: <%= job.status.capitalize %> |
                      Images: <%= job.images_found %> |
                      Created: <%= job.created_at.strftime("%B %d, %Y at %I:%M %p") %>
                    </p>
                  </div>
                  <% if job.done? && job.can_download?(current_user, session.id&.to_s, request.remote_ip) %>
                    <a href="/jobs/<%= job.uuid %>/download.zip"
                       class="bg-green-600 text-white px-4 py-2 rounded-md text-sm hover:bg-green-700">
                      Download
                    </a>
                  <% elsif job.done? %>
                    <span class="text-gray-500 text-sm">Downloaded</span>
                  <% else %>
                    <span class="text-blue-600 text-sm"><%= job.status.capitalize %></span>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-gray-600">No jobs yet. <a href="/" class="text-blue-600 hover:underline">Create your first job</a>.</p>
        <% end %>
      </div>

      <!-- Account Actions -->
      <div class="border-t border-gray-200 pt-6">
        <div class="flex space-x-4">
          <%= link_to "Back to Home", root_path, class: "bg-gray-600 text-white px-4 py-2 rounded-md text-sm hover:bg-gray-700" %>
          <%= link_to "Sign Out", destroy_user_session_path, method: :delete, class: "bg-red-600 text-white px-4 py-2 rounded-md text-sm hover:bg-red-700" %>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
async function upgradeToPremium() {
  try {
    const response = await fetch('/billing/checkout', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content
      }
    });

    const data = await response.json();

    if (data.checkout_url) {
      window.location.href = data.checkout_url;
    } else {
      alert('Error creating checkout session: ' + (data.error || 'Unknown error'));
    }
  } catch (error) {
    alert('Error upgrading to premium: ' + error.message);
  }
}
</script>