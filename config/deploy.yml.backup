# Backup of original deploy.yml
service: imagesweep

image: zelusottomayor/imagesweep

builder:
  arch: amd64
  cache: true

servers:
  web:
    hosts:
      - 143.110.169.251
    labels:
      traefik.http.routers.imagesweep.rule: Host(`imagescrapingtool.zelusottomayor.com`)
      traefik.http.routers.imagesweep.tls: true
      traefik.http.routers.imagesweep.tls.certresolver: letsencrypt
      traefik.http.services.imagesweep.loadbalancer.server.port: "80"
  workers:
    hosts:
      - 143.110.169.251
    cmd: bundle exec sidekiq

registry:
  username: zelusottomayor
  password:
    - KAMAL_REGISTRY_PASSWORD

env:
  clear:
    PORT: "80"
    REDIS_URL: redis://redis:6379/0
    RAILS_ENV: production
    RAILS_LOG_TO_STDOUT: "1"
  secret:
    - RAILS_MASTER_KEY
    - IMAGESWEEP_DATABASE_PASSWORD
    - POSTGRES_PASSWORD
    - DATABASE_URL

accessories:
  db:
    image: postgres:15
    host: 143.110.169.251
    port: 5432
    env:
      clear:
        POSTGRES_DB: imagesweep_production
        POSTGRES_USER: imagesweep
      secret:
        - POSTGRES_PASSWORD
    volumes:
      - /mnt/volume-lon1-01/postgres-data:/var/lib/postgresql/data

  redis:
    image: redis:7
    host: 143.110.169.251
    port: 6379
    volumes:
      - /mnt/volume-lon1-01/redis-data:/data

boot:
  limit: 10
  wait: 2